<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="何を・どれくらい・いつまでに届けたい？ <%= app_name %> で航空と海上を比較し、料金・リードタイムから自分に合った輸送サービスを見つけられます。" />
    <title><%= content_for?(:title) ? yield(:title) : "#{app_name} — 海外輸送比較" %></title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <%= stylesheet_link_tag 'application', media: 'all', data: { turbo_track: Rails.env.production? ? "reload" : "" } %>
    <%= javascript_importmap_tags %>
    <%= yield :head if content_for?(:head) %>
  </head>
  <body class="lit-body d-flex flex-column min-vh-100">
    <%= render "shared/flash" %>
    <%= render "shared/header" %>
    <main class="lit-main flex-grow-1 d-flex flex-column">
      <%= yield %>
    </main>
    <%= render "shared/footer" %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <%= yield :body_end if content_for?(:body_end) %>
  </body>
</html>
