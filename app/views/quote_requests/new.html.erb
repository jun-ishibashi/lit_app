<% content_for :title, "見積もりを依頼 | LIT APP" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">見積もりを依頼</h1>
    <p class="lit-breadcrumb mb-0">
      <%= link_to "トップ", root_path %> &gt; <%= link_to "サービス詳細", service_path(@service) %> &gt; 見積もり依頼
    </p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card mb-4">
          <div class="card-body lit-card-body">
            <p class="text-muted small mb-3">
              <%= @service.departure.name %> → <%= @service.destination.name %>（<%= @service.service_type.name %>）／<%= @service.provider.name %>
            </p>
            <%= form_with model: @quote_request, url: quote_requests_path, local: true do |f| %>
              <%= f.hidden_field :service_id %>
              <div class="mb-4">
                <h3 class="h6 mb-2">荷物情報（任意・あると見積もりが正確になります）</h3>
                <div class="row g-3">
                  <div class="col-md-4">
                    <%= f.label :weight_kg, "重量（kg）", class: "lit-form-label form-label" %>
                    <%= f.number_field :weight_kg, step: :any, placeholder: "例）100", class: "form-control" %>
                  </div>
                  <div class="col-md-4">
                    <%= f.label :volume_cbm, "容積（CBM）", class: "lit-form-label form-label" %>
                    <%= f.number_field :volume_cbm, step: :any, placeholder: "例）2.5", class: "form-control" %>
                  </div>
                  <div class="col-md-4">
                    <%= f.label :quantity, "個数", class: "lit-form-label form-label" %>
                    <%= f.number_field :quantity, placeholder: "例）10", class: "form-control" %>
                  </div>
                </div>
              </div>
              <div class="mb-4">
                <%= f.label :incoterm_id, "希望インコタームズ（任意）", class: "lit-form-label form-label" %>
                <p class="text-muted small mb-1">同じ条件で業者間を比較したいときに指定してください</p>
                <%= f.collection_select :incoterm_id, Incoterm.selectable, :id, :name, { include_blank: "指定しない" }, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <%= f.label :message, "メッセージ（任意）", class: "lit-form-label form-label" %>
                <%= f.text_area :message, rows: 5, class: "form-control", placeholder: "荷物の内容・希望納期・その他業者に伝えたいことを記入してください" %>
              </div>
              <div class="d-flex gap-2">
                <%= f.submit "依頼を送信", class: "btn btn-primary" %>
                <%= link_to "キャンセル", service_path(@service), class: "btn btn-outline-secondary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
