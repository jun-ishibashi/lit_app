<% content_for :title, (@as_provider ? "見積もり依頼一覧（業者） | LIT APP" : "見積もり依頼一覧 | LIT APP") %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title"><%= @as_provider ? "自社サービスへの見積もり依頼" : "わたしの見積もり依頼" %></h1>
    <p class="lit-breadcrumb mb-0">
      <%= link_to "トップ", root_path %> &gt; 見積もり依頼一覧
    </p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <% if @quote_requests.any? %>
      <div class="lit-table-wrap table-responsive">
        <table class="table lit-table">
          <thead>
            <tr>
              <% if @as_provider %><th>依頼者</th><% end %>
              <th>サービス</th>
              <th>依頼日</th>
              <th>ステータス</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @quote_requests.each do |qr| %>
              <tr>
                <% if @as_provider %>
                  <td><%= qr.user.name %></td>
                <% end %>
                <td>
                  <%= qr.service.departure.name %> → <%= qr.service.destination.name %><br>
                  <span class="small text-muted"><%= qr.service.provider.name %></span>
                </td>
                <td><%= qr.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td>
                  <span class="badge <%= qr.status == 'pending' ? 'bg-warning' : (qr.status == 'replied' ? 'bg-success' : 'bg-secondary') %>">
                    <%= qr.status == 'pending' ? '未対応' : (qr.status == 'replied' ? '返信済み' : '完了') %>
                  </span>
                </td>
                <td><%= link_to "詳細", quote_request_path(qr), class: "btn btn-sm btn-outline-primary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="lit-empty py-5">
        <i class="bi bi-inbox lit-empty-icon text-muted" aria-hidden="true"></i>
        <p class="lit-empty-title"><%= @as_provider ? "自社サービスへの見積もり依頼はまだありません" : "見積もり依頼はまだありません" %></p>
        <p class="small text-muted mb-0">
          <%= @as_provider ? "ユーザーがサービス詳細から「見積もりを依頼」すると、ここに一覧表示されます。" : "サービス詳細ページから「見積もりを依頼」で依頼できます。" %>
        </p>
        <% unless @as_provider %>
          <%= link_to "サービスを検索する", root_path, class: "btn btn-primary mt-3" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
