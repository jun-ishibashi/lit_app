<% content_for :title, "マイページ（業者） | LIT APP" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">マイページ（業者）</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; マイページ</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card mb-4">
          <div class="card-body lit-card-body">
            <dl class="row lit-dl mb-0">
              <dt class="col-sm-3">会社名</dt>
              <dd class="col-sm-9"><%= @provider.name %></dd>
              <dt class="col-sm-3">登録メールアドレス</dt>
              <dd class="col-sm-9"><%= @provider.email %></dd>
              <dt class="col-sm-3">メインサービスタイプ</dt>
              <dd class="col-sm-9"><%= @provider.service_type.name %></dd>
              <dt class="col-sm-3">紹介</dt>
              <dd class="col-sm-9"><%= @provider.introduction %></dd>
            </dl>
            <div class="lit-actions">
              <%= link_to "アカウント編集", edit_provider_registration_path, class: "btn btn-outline-primary" %>
              <%= link_to new_service_path, class: "btn btn-primary ms-auto" do %>
                <i class="bi bi-plus-lg me-1"></i>サービスを登録
              <% end %>
            </div>
          </div>
        </div>

        <h2 class="lit-section-title mb-3">提供サービス一覧</h2>
        <% if @services.any? %>
          <div class="lit-table-wrap table-responsive">
            <table class="table lit-table">
              <thead>
                <tr>
                  <th>出発地</th>
                  <th>到着地</th>
                  <th>料金</th>
                  <th>リードタイム</th>
                  <th>サービスタイプ</th>
                </tr>
              </thead>
              <tbody>
                <% @services.each do |service| %>
                  <tr>
                    <td><%= link_to service.departure.name, service_path(service) %></td>
                    <td><%= link_to service.destination.name, service_path(service) %></td>
                    <td><%= link_to "#{service.price}円", service_path(service) %></td>
                    <td><%= link_to "#{service.lead_time}日", service_path(service) %></td>
                    <td><%= link_to service.service_type.name, service_path(service) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="lit-empty py-4">
            <i class="bi bi-box lit-empty-icon" aria-hidden="true"></i>
            <p class="lit-empty-title">登録されたサービスはありません</p>
            <p class="small mb-3">サービスを登録すると一覧に表示されます。</p>
            <%= link_to new_service_path, class: "btn btn-primary" do %><i class="bi bi-plus-lg me-1"></i>サービスを登録<% end %>
          </div>
        <% end %>

        <div class="mt-4">
          <%= link_to :back, class: "btn btn-outline-secondary" do %><i class="bi bi-arrow-left me-1"></i>もどる<% end %>
        </div>
      </div>
    </div>
  </div>
</section>
