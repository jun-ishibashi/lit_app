<% content_for :title, "業者様はこちら | LIT APP" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">業者様向け</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; 業者様はこちら</p>
    <p class="small text-muted mt-2 mb-0">運送業者の方はログインまたは新規登録してください。</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-5">
        <div class="lit-card card">
          <div class="card-body lit-card-body text-center">
            <p class="mb-4">自社のサービス（ルート・料金・リードタイム）を登録・管理できます。</p>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
              <%= link_to new_provider_session_path, class: "btn btn-primary px-4" do %>
                <i class="bi bi-box-arrow-in-right me-2"></i>業者ログイン
              <% end %>
              <%= link_to new_provider_registration_path, class: "btn btn-outline-primary px-4" do %>
                <i class="bi bi-person-plus me-2"></i>業者登録
              <% end %>
            </div>
            <hr class="my-4">
            <%= link_to root_path, class: "btn btn-outline-secondary btn-sm" do %>
              <i class="bi bi-arrow-left me-1"></i>トップへ戻る
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
