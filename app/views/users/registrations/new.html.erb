<% content_for :title, "新規登録 | #{app_name}" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">ユーザー登録</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; 新規登録</p>
    <p class="small text-muted mt-2 mb-0">ユーザー情報を入力してください</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card">
          <div class="card-body lit-card-body">
            <%= form_with model: @user, url: user_registration_path, local: true do |f| %>
              <%= render "users/shared/error_messages", resource: resource %>
              <div class="row g-3">
                <div class="col-12">
                  <label class="lit-form-label form-label">お名前</label>
                  <%= f.text_area :name, class: "form-control", id: "name", placeholder: "名前を入力", maxlength: "40", autofocus: true, rows: 1 %>
                </div>
                <div class="col-12">
                  <%= f.label :email, class: "lit-form-label form-label" %>
                  <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
                </div>
                <div class="col-md-6">
                  <%= f.label :password, class: "lit-form-label form-label" %>
                  <% if @minimum_password_length %>
                    <span class="text-muted small">（<%= @minimum_password_length %>文字以上）</span>
                  <% end %>
                  <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
                </div>
                <div class="col-md-6">
                  <%= f.label :password_confirmation, class: "lit-form-label form-label" %>
                  <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
                </div>
                <div class="col-md-6">
                  <%= f.label :user_type_id, "ユーザータイプ", class: "lit-form-label form-label" %>
                  <%= f.collection_select :user_type_id, UserType.all, :id, :name, {}, { class: "form-select" } %>
                </div>
                <div class="col-md-6">
                  <%= f.label :product_id, "メインプロダクト", class: "lit-form-label form-label" %>
                  <%= f.collection_select :product_id, Product.all, :id, :name, {}, { class: "form-select" } %>
                </div>
                <div class="col-12">
                  <%= f.label :introduction, class: "lit-form-label form-label" %>
                  <%= f.text_area :introduction, rows: 4, class: "form-control", id: "introduction", placeholder: "輸送上重視される点など（任意）" %>
                </div>
              </div>
              <%= f.submit "登録する", class: "btn btn-primary mt-3 px-4" %>
            <% end %>
            <div class="lit-auth-links small mt-3">
              <%= render "users/shared/links" %>
            </div>
            <div class="mt-3">
              <%= link_to "トップへ戻る", root_path, class: "btn btn-outline-secondary btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
