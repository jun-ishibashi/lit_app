<%= render "shared/header" %>

<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">ユーザーログイン</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; ログイン</p>
    <p class="small text-muted mt-2 mb-0">メールアドレスとパスワードを入力してください</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="lit-card card">
          <div class="card-body lit-card-body">
            <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
              <div class="mb-3">
                <%= f.label :email, class: "lit-form-label form-label" %>
                <%= f.email_field :email, class: "form-control", autofocus: true, autocomplete: "email", placeholder: "example@email.com" %>
              </div>
              <div class="mb-3">
                <%= f.label :password, class: "lit-form-label form-label" %>
                <%= f.password_field :password, class: "form-control", autocomplete: "current-password" %>
              </div>
              <% if devise_mapping.rememberable? %>
                <div class="mb-4 form-check">
                  <%= f.check_box :remember_me, class: "form-check-input" %>
                  <%= f.label :remember_me, class: "form-check-label small" %>
                </div>
              <% end %>
              <%= f.submit "ログイン", class: "btn btn-primary w-100 py-2 mb-3" %>
            <% end %>
            <div class="lit-auth-links small">
              <%= render "users/shared/links" %>
            </div>
            <hr class="my-3">
            <%= link_to root_path, class: "btn btn-outline-secondary btn-sm w-100" do %>
              <i class="bi bi-house me-1"></i>トップへ戻る
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%= render "shared/footer" %>
