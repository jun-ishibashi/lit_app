<% content_for :title, "サービス編集 | LIT APP" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">サービス編集</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; <%= link_to "サービス詳細", service_path(@service) %> &gt; 編集</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card">
          <div class="card-body lit-card-body">
            <%= form_with model: @service, local: true do |f| %>
              <div class="mb-4">
                <label class="lit-form-label form-label">出発地</label>
                <p class="text-muted small mb-1">貨物を出荷する都市を選択してください</p>
                <%= f.collection_select :departure_id, Departure.ordered, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">到着地</label>
                <p class="text-muted small mb-1">貨物を届ける都市を選択してください</p>
                <%= f.collection_select :destination_id, Destination.ordered, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">サービスタイプ</label>
                <p class="text-muted small mb-1">輸送手段を選択してください</p>
                <%= f.collection_select :service_type_id, ServiceType.all, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">料金</label>
                <p class="text-muted small mb-1">料金（円）を入力してください</p>
                <%= f.text_field :price, placeholder: "例）30,000", class: "form-control" %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">リードタイム</label>
                <p class="text-muted small mb-1">リードタイム（日数）を入力してください</p>
                <%= f.text_field :lead_time, placeholder: "例）3", class: "form-control" %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">オプション</label>
                <p class="text-muted small mb-1">対応可能なオプションを選択してください</p>
                <%= f.collection_select :option_id, Option.all, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">説明</label>
                <p class="text-muted small mb-1">サービスの説明や概要を入力してください（任意）</p>
                <%= f.text_area :description, rows: 5, class: "form-control" %>
              </div>
              <div class="d-flex gap-2 flex-wrap">
                <%= f.submit "更新する", class: "btn btn-primary px-4" %>
                <%= link_to "キャンセル", service_path(@service), class: "btn btn-outline-secondary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
