<% content_for :title, "サービス登録 | LIT APP" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">輸送サービスを登録</h1>
    <p class="lit-breadcrumb mb-0"><%= link_to "トップ", root_path %> &gt; サービス登録</p>
    <p class="small text-muted mt-2 mb-0">ルートと運賃で簡単に登録できます</p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card">
          <div class="card-body lit-card-body">
            <%= form_with model: @service, local: true do |f| %>
              <div class="mb-4">
                <label class="lit-form-label form-label">出発地</label>
                <p class="text-muted small mb-1">貨物を出荷する都市を選択してください</p>
                <%= f.collection_select :departure_id, Departure.ordered, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">到着地</label>
                <p class="text-muted small mb-1">貨物を届ける都市を選択してください</p>
                <%= f.collection_select :destination_id, Destination.ordered, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">サービスタイプ</label>
                <p class="text-muted small mb-1">輸送手段を選択してください</p>
                <%= f.collection_select :service_type_id, ServiceType.all, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">作業範囲</label>
                <p class="text-muted small mb-1">通関を含むか・港/ドア間など、海外貿易で重要な範囲を選んでください（任意）</p>
                <%= f.collection_select :service_scope_id, ServiceScope.all, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">インコタームズ（任意）</label>
                <p class="text-muted small mb-1">貿易条件を選ぶと、同じ条件で業者間の比較がしやすくなります</p>
                <%= f.collection_select :incoterm_id, Incoterm.selectable, :id, :name, { include_blank: "指定しない" }, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">コンテナサイズ（任意）</label>
                <p class="text-muted small mb-1">海上FCLの場合は 20ft / 40ft を選べます</p>
                <%= f.collection_select :container_size_id, ContainerSize.selectable, :id, :name, { include_blank: "該当しない" }, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">料金</label>
                <p class="text-muted small mb-1">料金（<%= price_unit_description %>）を入力してください。税の扱いは「料金に含まれるもの」で補足できます。</p>
                <%= f.text_field :price, placeholder: "例）30000", class: "form-control" %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">料金の種別</label>
                <p class="text-muted small mb-1">総額か、重量・容積・コンテナあたりの単価かを選んでください</p>
                <%= f.select :price_type, options_for_select([["総額（円）", "total"], ["円/kg", "per_kg"], ["円/CBM", "per_cbm"], ["円/コンテナ", "per_container"]], @service.price_type), {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">料金単位（コンテナの場合）</label>
                <p class="text-muted small mb-1">料金の種別が「円/コンテナ」のときは 20ft または 40ft を選んでください</p>
                <%= f.select :price_unit, options_for_select([["—", ""], ["20ft", "20ft"], ["40ft", "40ft"]], @service.price_unit), {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">料金に含まれるもの（任意）</label>
                <p class="text-muted small mb-1">例）ALL IN（諸経費込み）、基本運賃のみ、基本運賃+THC、税別</p>
                <%= f.text_field :price_includes, placeholder: "例）ALL IN、税別", class: "form-control" %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">リードタイム</label>
                <p class="text-muted small mb-1">リードタイム（日数）を入力してください</p>
                <%= f.text_field :lead_time, placeholder: "例）3", class: "form-control" %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">オプション</label>
                <p class="text-muted small mb-1">対応可能なオプションを選択してください</p>
                <%= f.collection_select :option_id, Option.all, :id, :name, {}, { class: "form-select" } %>
              </div>
              <div class="mb-4">
                <label class="lit-form-label form-label">説明</label>
                <p class="text-muted small mb-1">サービスの説明や概要を入力してください（任意）</p>
                <%= f.text_area :description, rows: 5, class: "form-control" %>
              </div>
              <div class="d-flex gap-2 flex-wrap">
                <%= f.submit "登録する", class: "btn btn-primary px-4" %>
                <%= link_to "キャンセル", root_path, class: "btn btn-outline-secondary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
