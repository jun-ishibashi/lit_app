<%= render "shared/header" %>

<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">検索結果</h1>
    <p class="lit-breadcrumb mb-0">
      <%= link_to "トップ", root_path %> &gt; 検索結果
    </p>
    <p class="small text-muted mt-2 mb-0">
      本日：<%= @today %>
      <% if @shipping_date.present? %> ・ 出荷希望日：<%= @shipping_date %><% end %>
      <% if @arrival_date.present? %> ・ 到着希望日：<%= @arrival_date %><% end %>
    </p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <% if @services.length != 0 %>
      <p class="small text-muted mb-3"><%= @services.size %>件のサービスが見つかりました</p>
      <div class="lit-table-wrap table-responsive">
        <table class="table lit-table">
          <thead>
            <tr>
              <th>出発地</th>
              <th>到着地</th>
              <th>料金</th>
              <th>リードタイム</th>
              <th>サービスタイプ</th>
              <th>プロバイダー</th>
              <% if @shipping_date.present? %><th>最短到着日</th><% end %>
              <% if @arrival_date.present? %><th>必要出荷日</th><% end %>
            </tr>
          </thead>
          <tbody>
            <% @services.each do |service| %>
              <tr>
                <td><%= link_to service.departure.name, service_path(service) %></td>
                <td><%= link_to service.destination.name, service_path(service) %></td>
                <td><%= link_to "#{service.price}円", service_path(service) %></td>
                <td><%= link_to "#{service.lead_time}日", service_path(service) %></td>
                <td><%= link_to service.service_type.name, service_path(service) %></td>
                <td><%= link_to service.provider.name, service_path(service) %></td>
                <% if @shipping_date.present? %>
                  <td><%= link_to (@shipping_date + service.lead_time.to_i).to_s, service_path(service), class: "text-success" %></td>
                <% end %>
                <% if @arrival_date.present? %>
                  <td>
                    <% if @today < (@arrival_date - service.lead_time.to_i) %>
                      <%= link_to (@arrival_date - service.lead_time.to_i).to_s, service_path(service), class: "text-success" %>
                    <% else %>
                      <span class="text-danger small">出荷が間に合いません</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="lit-empty">
        <i class="bi bi-search lit-empty-icon text-muted" aria-hidden="true"></i>
        <p class="lit-empty-title">該当するサービスはありません</p>
        <p class="small mb-4">条件を変えて再度検索してみてください。</p>
        <%= link_to root_path, class: "btn btn-primary" do %>
          <i class="bi bi-arrow-left me-1"></i>検索条件を変える
        <% end %>
      </div>
    <% end %>
    <div class="text-center mt-4">
      <%= link_to root_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-house me-1"></i>トップへ戻る
      <% end %>
    </div>
  </div>
</section>

<%= render "shared/footer" %>
