<% content_for :title, "検索結果 | #{app_name}" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">検索結果</h1>
    <p class="lit-breadcrumb mb-0">
      <%= link_to "トップ", root_path %> &gt; 検索結果
    </p>
    <p class="small text-muted mt-2 mb-0">
      本日：<%= @today %>
      <% if @shipping_date.present? %> ・ 出荷希望日：<%= @shipping_date %><% end %>
      <% if @arrival_date.present? %> ・ 到着希望日：<%= @arrival_date %><% end %>
    </p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <% if @services.length != 0 %>
      <% min_price = @services.map(&:price).compact.min %>
      <% min_lead_time = @services.map(&:lead_time).compact.min %>
      <% q = (params[:q] || {}).to_h %>
      <% filter_pairs = q.slice("departure_id_eq", "destination_id_eq", "service_type_id_eq", "service_scope_id_eq", "incoterm_id_eq", "container_size_id_eq", "provider_id_eq", "sorts").reject { |_, v| v.blank? } %>
      <% has_chips = filter_pairs.any? || @shipping_date.present? || @arrival_date.present? || params[:cargo_volume].present? %>
      <% if has_chips %>
        <div class="lit-filter-chips">
          <% filter_pairs.each do |key, value| %>
            <% label = search_filter_label(key, value) %>
            <% next if label.blank? %>
            <span class="lit-filter-chip">
              <span class="lit-filter-chip-label"><%= search_filter_key_label(key) %>:</span>
              <%= label %>
            </span>
          <% end %>
          <% if @shipping_date.present? %>
            <span class="lit-filter-chip"><span class="lit-filter-chip-label">出荷希望日:</span><%= @shipping_date %></span>
          <% end %>
          <% if @arrival_date.present? %>
            <span class="lit-filter-chip"><span class="lit-filter-chip-label">到着希望日:</span><%= @arrival_date %></span>
          <% end %>
          <% if params[:cargo_volume].present? && cargo_volume_label(params[:cargo_volume]).present? %>
            <span class="lit-filter-chip"><span class="lit-filter-chip-label">貨物の目安:</span><%= cargo_volume_label(params[:cargo_volume]) %></span>
          <% end %>
        </div>
      <% end %>
      <p class="lit-search-result-count"><%= @services.size %>件のサービスが見つかりました（★最安、⚡最短などの目印を参考にしてください）</p>
      <div class="lit-search-result-guide mb-3">
        <p class="small text-muted mb-0">
          <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
          航空は早く・少量向け、海上は大量でコストを抑えたいとき向け。料金とリードタイムを比べて、納期と予算に合うものを選んでください。複数業者を比較してから見積もりを依頼すると、より適切に選べます。<br>
          <strong>作業範囲</strong>（通関込み・運送のみなど）は海外貿易では重要です。通関を業者に任せるか自分で手配するかで、作業範囲で絞り込んで比較してください。
          <% if params[:cargo_volume] == "small" %>
            <span class="d-block mt-1">少量の目安で検索中：航空を重点的に見てみましょう。</span>
          <% elsif params[:cargo_volume] == "large" %>
            <span class="d-block mt-1">大量の目安で検索中：海上（LCL・FCL）もあわせて比較してみましょう。</span>
          <% end %>
        </p>
      </div>
      <div class="lit-table-wrap table-responsive">
        <table class="table lit-table">
          <thead>
            <tr>
              <th>出発地</th>
              <th>到着地</th>
              <th>料金（円）</th>
              <th>リードタイム</th>
              <th>サービスタイプ</th>
              <th>作業範囲</th>
              <th>業者</th>
              <% if @shipping_date.present? %><th>最短到着日</th><% end %>
              <% if @arrival_date.present? %><th>必要出荷日</th><% end %>
            </tr>
          </thead>
          <tbody>
            <% @services.each do |service| %>
              <tr>
                <td><%= link_to service.departure.name, service_path(service) %></td>
                <td><%= link_to service.destination.name, service_path(service) %></td>
                <td>
                  <%= link_to format_price_for_service(service), service_path(service) %>
                  <% if service.price.present? && service.price == min_price %>
                    <span class="badge bg-success-subtle text-success border ms-1">★ 最安の候補</span>
                  <% end %>
                </td>
                <td>
                  <%= link_to "#{service.lead_time}日", service_path(service) %>
                  <% if service.lead_time.present? && service.lead_time == min_lead_time %>
                    <span class="badge bg-info-subtle text-info border ms-1">⚡ 最短の候補</span>
                  <% end %>
                </td>
                <td><%= link_to service.service_type.name, service_path(service) %></td>
                <td><%= service.service_scope_id.present? && service.service_scope.id != 1 ? service.service_scope.name : "—" %></td>
                <td><%= link_to service.provider.name, service_path(service) %></td>
                <% if @shipping_date.present? %>
                  <td><%= link_to (@shipping_date + service.lead_time.to_i).to_s, service_path(service), class: "text-success" %></td>
                <% end %>
                <% if @arrival_date.present? %>
                  <td>
                    <% if @today < (@arrival_date - service.lead_time.to_i) %>
                      <%= link_to (@arrival_date - service.lead_time.to_i).to_s, service_path(service), class: "text-success" %>
                    <% else %>
                      <span class="text-danger small">出荷が間に合いません</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="lit-empty">
        <i class="bi bi-search lit-empty-icon text-muted" aria-hidden="true"></i>
        <p class="lit-empty-title">該当するサービスはありません</p>
        <p class="small mb-4">条件を変えて再度検索してみてください。</p>
        <%= link_to root_path(search_refine_query_params), class: "btn btn-primary" do %>
          <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>検索条件を変える
        <% end %>
      </div>
    <% end %>
    <div class="text-center mt-4 pt-2">
      <%= link_to root_path(search_refine_query_params), class: "btn btn-outline-primary me-2" do %>
        <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>条件を変えて検索
      <% end %>
      <%= link_to root_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-house me-1" aria-hidden="true"></i>トップへ戻る
      <% end %>
    </div>
  </div>
</section>
