<% content_for :title, "サービス詳細 | #{app_name}" %>
<section class="lit-page-header">
  <div class="container">
    <h1 class="lit-page-title">サービス詳細</h1>
    <p class="lit-breadcrumb mb-0">
      <%= link_to "トップ", root_path %> &gt; サービス詳細
    </p>
  </div>
</section>

<section class="lit-section bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="lit-card card">
          <div class="card-body lit-card-body">
            <div class="row mb-4 align-items-center">
              <div class="col-12 col-sm-6 mb-2 mb-sm-0">
                <span class="badge bg-light text-primary border border-primary px-3 py-2"><%= @service.service_type.name %></span>
              </div>
              <div class="col-12 col-sm-6 text-start text-sm-end">
                <span class="fs-4 fw-bold text-dark"><%= format_price_for_service(@service) %></span>
                <span class="small text-muted ms-1">（<%= price_unit_description %>）</span>
                <span class="ms-2 text-muted">リードタイム <%= @service.lead_time %>日</span>
              </div>
            </div>
            <% if @service.price_includes.present? %>
              <p class="text-muted small mb-3">料金に含まれるもの：<%= @service.price_includes %></p>
            <% end %>
            <dl class="row lit-dl">
              <dt class="col-sm-4">出発地</dt>
              <dd class="col-sm-8"><%= @service.departure.name %></dd>
              <dt class="col-sm-4">到着地</dt>
              <dd class="col-sm-8"><%= @service.destination.name %></dd>
              <dt class="col-sm-4">インコタームズ</dt>
              <dd class="col-sm-8"><%= @service.incoterm_id.present? && @service.incoterm&.id != 1 ? @service.incoterm.name : "—" %></dd>
              <dt class="col-sm-4">コンテナサイズ</dt>
              <dd class="col-sm-8"><%= @service.container_size_id.present? && @service.container_size&.id != 1 ? @service.container_size.name : "—" %></dd>
              <dt class="col-sm-4">オプション</dt>
              <dd class="col-sm-8"><%= @service.option.name %></dd>
              <dt class="col-sm-4">作業範囲</dt>
              <dd class="col-sm-8">
                <% if @service.service_scope_id.present? && @service.service_scope.id != 1 %>
                  <%= @service.service_scope.name %>
                  <% if @service.service_scope.description.present? %>
                    <span class="small text-muted d-block"><%= @service.service_scope.description %></span>
                  <% end %>
                <% else %>
                  —
                <% end %>
              </dd>
              <dt class="col-sm-4">説明</dt>
              <dd class="col-sm-8"><%= @service.description %></dd>
              <dt class="col-sm-4">業者</dt>
              <dd class="col-sm-8"><%= @service.provider.name %></dd>
            </dl>
            <div class="lit-actions">
              <% if user_signed_in? %>
                <%= link_to new_quote_request_path(service_id: @service.id), class: "btn btn-primary" do %><i class="bi bi-chat-dots me-1"></i>見積もりを依頼<% end %>
                <p class="small text-muted mt-2 mb-0">
                  できれば他のサービスとも料金と日数を比べて、2社以上に見積もりを依頼すると安心です。
                </p>
              <% end %>
              <% if provider_signed_in? && current_provider == @service.provider %>
                <%= link_to edit_service_path(@service), class: "btn btn-outline-primary" do %><i class="bi bi-pencil me-1"></i>編集<% end %>
                <%= link_to service_path(@service), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, class: "btn btn-outline-danger" do %><i class="bi bi-trash me-1"></i>削除<% end %>
              <% end %>
              <%= link_to :back, class: "btn btn-outline-secondary ms-auto" do %><i class="bi bi-arrow-left me-1"></i>もどる<% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
