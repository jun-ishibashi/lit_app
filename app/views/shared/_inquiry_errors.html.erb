<% if inquiry.errors.any? %>
  <div id="error_explanation" class="alert alert-danger mb-4">
    <h3 class="alert-heading h6"><%= inquiry.errors.count %>件のエラーがあります</h3>
    <ul class="mb-0 ps-3">
      <% inquiry.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
